<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Extend the General Settings view -->
    <record id="view_res_config_settings_inherit" model="ir.ui.view">
        <field name="name">res.config.settings.inherit.mbk.fm</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <!-- Create a new separator for custom settings if needed -->
                <div class="app_settings_block" data-string="CAFM" id="mbk_fm" string="CAFM" data-key="mbk_fm">
                    <h2>CAFM Settings</h2>
                    <div class="row mt16 o_settings_container" id="mbk_fm_setting">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_right_pane">
                                <field name="mbk_fm_material_request_approval_required"/>
                                <div class="text-muted">
                                    Enable or disable approval for material requests.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
    <record id="mbk_fm_config_action" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module' : 'mbk_fm', 'bin_size': False}</field>
    </record>

    <menuitem id="mbk_fm_config_settings_menu" name="Settings"
              parent="menu_mbk_fm_config" sequence="0" action="mbk_fm_config_action"
              groups="base.group_no_one"/>
</odoo>
