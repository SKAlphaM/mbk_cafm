<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mbk_fm_ticket_type_tree" model="ir.ui.view">
        <field name="name">mbk_fm.ticket_type.tree</field>
        <field name="model">mbk_fm.ticket_type</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" string="Ticket Type Name"/>
                <field name="code"/>
                <field name="team_id"/>
                <field name="technician_id"/>
                <field name="is_approval_required"/>
            </list>
        </field>
    </record>
    <record id="view_mbk_fm_ticket_type_form" model="ir.ui.view">
        <field name="name">mbk_fm.ticket_type.form</field>
        <field name="model">mbk_fm.ticket_type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_tickets"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-wrench">
                            <field string="Maintenance" name="maintenance_count" widget="statinfo"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="team_id" options="{'no_create': True}"/>
                            <field name="technician_id" options="{'no_create': True}"/>
                            <field name="is_approval_required"/>
                            <field name="timeframe"/>
                        </group>
                        <group>
                            <field name="code"/>
                            <field name="color" widget="color_picker"/>
                            <field name="company_id" invisible="1"/>
                            <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
                <!-- Chatter -->
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>
    <record id="view_mbk_fm_ticket_type_search" model="ir.ui.view">
        <field name="name">mbk_fm.ticket_type.search</field>
        <field name="model">mbk_fm.ticket_type</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Ticket Type Name"
                       filter_domain="['|', ('name', 'ilike', self), ('code', 'ilike', self)]"/>
                <field name="code"/>
                <field name="team_id"/>
                <filter name="filter_type_archived" string="Archived" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="action_mbk_fm_ticket_type" model="ir.actions.act_window">
        <field name="name">Ticket Types</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">mbk_fm.ticket_type</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Ticket Type
            </p>
        </field>
    </record>

    <menuitem id="menu_mbk_fm_ticket_type"
              name="Ticket Types"
              action="action_mbk_fm_ticket_type"
              parent="menu_mbk_fm_config"
              sequence="10"/>
</odoo>