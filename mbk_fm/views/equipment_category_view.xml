<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mbk_fm_equipment_category_tree" model="ir.ui.view">
        <field name="name">mbk_fm.equipment_category.tree</field>
        <field name="model">mbk_fm.equipment_category</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="team_id"/>
                <field name="technician_id"/>
            </list>
        </field>
    </record>

    <record id="view_mbk_fm_equipment_category_form" model="ir.ui.view">
        <field name="name">mbk_fm.equipment_category.form</field>
        <field name="model">mbk_fm.equipment_category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_equipments"
                            class="oe_stat_button"
                            icon="fa-cubes"
                            type="object">
                            <field string="Equipment" name="equipment_count" widget="statinfo"/>
                        </button>
                        <button name="action_view_tickets"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-wrench">
                            <field string="Maintenance" name="maintenance_count" widget="statinfo"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="team_id" options="{'no_create': True}"/>
                            <field name="technician_id" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="code"/>
                            <field name="color" widget="color_picker"/>
                            <field name="company_id" invisible="1"/>
                            <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="note"/>
                    </group>
                </sheet>
                <!-- Chatter -->
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>
    <record id="view_mbk_fm_equipment_category_search" model="ir.ui.view">
        <field name="name">mbk_fm.equipment_category.search</field>
        <field name="model">mbk_fm.equipment_category</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Ticket Type Name"
                       filter_domain="['|', ('name', 'ilike', self), ('code', 'ilike', self)]"/>
                <field name="code"/>
                <field name="team_id"/>
                <field name="technician_id"/>
                <filter name="filter_type_archived" string="Archived" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="action_mbk_fm_equipment_category" model="ir.actions.act_window">
        <field name="name">Equipment Category</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">mbk_fm.equipment_category</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Equipment Category
            </p>
        </field>
    </record>


    <menuitem id="menu_mbk_fm_equipment_category"
              name="Equipment Category"
              action="action_mbk_fm_equipment_category"
              parent="menu_mbk_fm_config"
              sequence="20"/>
</odoo>