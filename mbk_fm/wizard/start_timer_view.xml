<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mbk_fm_start_timer" model="ir.ui.view">
        <field name="name">mbk_fm.start_timer.wizard.form</field>
        <field name="model">mbk_fm.start_timer_wizard</field>
        <field name="arch" type="xml">
            <form name="Report Options">
                <group>
                    <field name="ticket_id" invisible="1"/>
                    <field name="technician_id" options="{'no_create': True, 'no_create_edit':True}"/>
                    <field name="member_ids" widget="many2many_tags" options="{'no_create': True}" invisible="not technician_id"/>
                    <field name="comment" options="{'no_create': True, 'no_create_edit':True}"/>
                </group>
                <footer>
                    <button name="action_start_timer" icon="fa-play" class="btn-success" type="object" default_focus="1"/>
                    <button string="Discard" class="btn-secondary" special="cancel" data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_mbk_fm_start_timer" model="ir.actions.act_window">
        <field name="name">Start Timer</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">mbk_fm.start_timer_wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>