<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mbk_cafm_attachment_tree" model="ir.ui.view">
        <field name="name">mbk_cafm.attachment.tree</field>
        <field name="model">mbk_cafm.attachment</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="res_name"/>
                <field name="res_model"/>
                <field name="company_id"/>
                <field name="source_created_user"/>
                <field name="source_created_date"/>
            </list>
        </field>
    </record>

    <record id="view_mbk_cafm_attachment_form" model="ir.ui.view">
        <field name="name">mbk_cafm.attachment.form</field>
        <field name="model">mbk_cafm.attachment</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="remote_server_id"/>
                            <field name="description"/>
                            <field name="res_name"/>
                            <field name="res_model"/>
                            <field name="res_field"/>
                            <field name="company_id"/>

                        </group>
                        <group>
                            <field name="doc_attachment_id" widget="many2many_binary" class="oe_inline"/>
                            <field name="source_created_user"/>
                	    <field name="source_created_date"/>
                        </group>
                    </group>
                </sheet>
                <!-- Chatter -->
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>
    <record id="view_mbk_cafm_attachment_search" model="ir.ui.view">
        <field name="name">mbk_cafm.attachment.search</field>
        <field name="model">mbk_cafm.attachment</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
                <field name="res_name"/>
                <field name="res_model"/>
                <field name="source_created_user"/>
                <field name="source_created_date"/>
            </search>
        </field>
    </record>

    <record id="action_mbk_cafm_attachment" model="ir.actions.act_window">
        <field name="name">MBK Attachments</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">mbk_cafm.attachment</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">

            </p>
        </field>
    </record>



</odoo>
