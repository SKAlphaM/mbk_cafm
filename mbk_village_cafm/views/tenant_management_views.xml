<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- =========================
         TREE / LIST VIEW
    ========================== -->
    <record id="view_mbk_village_tenant_tree" model="ir.ui.view">
        <field name="name">mbk.village.tenant.tree</field>
        <field name="model">mbk_village.tenant</field>
        <field name="arch" type="xml">
            <list string="Tenants">
                <field name="name"/>
                <field name="arabic_full_name"/>
                <field name="nationality"/>
                <field name="company"/>
                <field name="contact_no"/>
                <field name="room_code"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <!-- =========================
         FORM VIEW
    ========================== -->
    <record id="view_mbk_village_tenant_form" model="ir.ui.view">
        <field name="name">mbk.village.tenant.form</field>
        <field name="model">mbk_village.tenant</field>
        <field name="arch" type="xml">
            <form string="Tenant">
                <header>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <field name="image_1920" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Tenant Name"/>
                        </h1>
                        <h1>
                            <field name="access_card" placeholder="Access Card" required="1"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="arabic_full_name"/>
                            <field name="date_of_birth"/>
                            <field name="nationality"/>
                            <field name="company"/>
                        </group>
                        <group>
                            <field name="contact_no"/>
                            <field name="room_code"/>

                            <!--                            <field name="status" widget="statusbar"/>-->
                        </group>
                    </group>

                    <notebook>
                        <page string="Services">
                            <group>
                                <field name="counter_data"/>
                                <field name="mess_hall_services"/>
                                <field name="laundry_services"/>
                            </group>
                        </page>

                        <!--                        <page string="Image">-->
                        <!--                            <group>-->
                        <!--                                <field name="image_1920" widget="image" class="oe_avatar" options="{'preview_image': 'image_1920'}"/>-->
                        <!--                            </group>-->
                        <!--                        </page>-->
                    </notebook>
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- =========================
         KANBAN VIEW
    ========================== -->
    <record id="view_mbk_village_tenant_kanban" model="ir.ui.view">
        <field name="name">mbk.village.tenant.kanban</field>
        <field name="model">mbk_village.tenant</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status">
                <field name="name"/>
                <field name="company"/>
                <field name="room_code"/>
                <field name="contact_no"/>
                <field name="nationality"/>
                <field name="status"/>
                <field name="image_1920"/>

                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record">
                            <div class="d-flex align-items-center">
<!--                                <div class="me-3">-->
<!--                                    <img t-att-src="kanban_image('mbk_village.tenant', 'image_1920', record.id.raw_value)" alt="Tenant" style="width:70px; height:70px; object-fit:cover; border-radius:8px;"/>-->
<!--                                </div>-->
<!--                                <div class="o_kanban_image">-->
<!--                                                    <img alt="Contact image" t-att-src="kanban_image('res.partner', 'avatar_128', record.id.raw_value)"/>-->
<!--                                                </div>-->
                                <div>
                                    <div>
                                        <strong>
                                            <field name="name"/>
                                        </strong>
                                    </div>
                                    <div>Company:
                                        <field name="company"/>
                                    </div>
                                    <div>Room:
                                        <field name="room_code"/>
                                    </div>
                                    <div>Contact:
                                        <field name="contact_no"/>
                                    </div>
                                    <div>Status:
                                        <field name="status"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- =========================
         SEARCH VIEW
    ========================== -->
    <record id="view_mbk_village_tenant_search" model="ir.ui.view">
        <field name="name">mbk.village.tenant.search</field>
        <field name="model">mbk_village.tenant</field>
        <field name="arch" type="xml">
            <search string="Search Tenants">
                <field name="name"/>
                <field name="arabic_full_name"/>
                <field name="nationality"/>
                <field name="company"/>
                <field name="contact_no"/>
                <field name="room_code"/>
                <field name="status"/>

                <filter string="Active" name="filter_active" domain="[('status','=','active')]"/>
                <filter string="Inactive" name="filter_inactive" domain="[('status','=','inactive')]"/>
                <filter string="Pending" name="filter_pending" domain="[('status','=','pending')]"/>
                <filter string="Terminated" name="filter_terminated" domain="[('status','=','terminated')]"/>

                <separator/>

                <group expand="0" string="Group By">
                    <filter string="Status" name="group_by_status" context="{'group_by': 'status'}"/>
                    <filter string="Company" name="group_by_company" context="{'group_by': 'company'}"/>
                    <filter string="Nationality" name="group_by_nationality" context="{'group_by': 'nationality'}"/>
                    <filter string="Room Code" name="group_by_room_code" context="{'group_by': 'room_code'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- =========================
         ACTION
    ========================== -->
    <record id="action_mbk_village_tenant" model="ir.actions.act_window">
        <field name="name">Tenants</field>
        <field name="res_model">mbk_village.tenant</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_mbk_village_tenant_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first tenant record
            </p>
        </field>
    </record>

    <!-- =========================
         MAIN MENU
    ========================== -->
    <menuitem id="menu_mbk_village_root" name="Village Management" sequence="10"/>

    <menuitem id="menu_mbk_village_tenant_main" name="Tenants" parent="menu_mbk_village_root" action="action_mbk_village_tenant" sequence="20"/>

</odoo>