        <field name="name">Cheque sequence</field>
        <field name="code">mbk_pms.cheque_sequence</field>
        <field name="prefix">CHQ</field>
        <field name="padding">5</field>
        <field eval="1" name="number_next"/>
        <field eval="1" name="number_increment"/>
        <field eval="False" name="company_id"/>
    </record>

    <!--Process Bounced Cheque Sequence -->
    <record id="sequence_pms_process_bounced" model="ir.sequence">
        <field name="name">Process Bounced sequence</field>
        <field name="code">mbk_pms.process_bounced</field>
        <field name="prefix">PB</field>
        <field name="padding">4</field>
        <field eval="1" name="number_next"/>
        <field eval="1" name="number_increment"/>
        <field eval="False" name="company_id"/>
    </record>

    <!-- Contract Approval activities, for automatic generation mainly -->
    <record id="mail_act_pms_contract_approval" model="mail.activity.type">
        <field name="name">To Approve</field>
        <field name="icon">fa-check</field>
        <field name="res_model">mbk_pms.contract</field>
    </record>

    <!-- Cheque Hold Request Approval activities, for automatic generation mainly -->
    <record id="mail_act_pms_chq_hold_approval" model="mail.activity.type">
        <field name="name">To Approve</field>
        <field name="icon">fa-check</field>
        <field name="res_model">mbk_pms.cheque_hold</field>
    </record>

    <!-- Renewal Offer Letter Approval activities, for automatic generation mainly -->
    <record id="mail_act_pms_renewal_offer_approval" model="mail.activity.type">
        <field name="name">To Approve</field>
        <field name="icon">fa-check</field>
        <field name="res_model">mbk_pms.renewal_offer</field>
    </record>

    <!-- Lease Offer Letter Approval activities, for automatic generation mainly -->
    <record id="mail_act_pms_lease_offer_approval" model="mail.activity.type">
        <field name="name">To Approve</field>
        <field name="icon">fa-check</field>
        <field name="res_model">mbk_pms.lease_offer</field>
