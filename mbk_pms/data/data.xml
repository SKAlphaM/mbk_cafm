    <!-- Break Contract Approval activities, for automatic generation mainly -->
    <record id="mail_act_pms_break_contract_approval" model="mail.activity.type">
        <field name="name">To Approve</field>
        <field name="icon">fa-check</field>
        <field name="res_model">mbk_pms.break_contract</field>
    </record>

    </data>
</odoo>