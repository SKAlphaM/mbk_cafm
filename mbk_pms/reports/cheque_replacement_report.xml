<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="cheque_replacement">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="web.external_layout">
                        <div class="page">
                            <div class="oe_structure"/>
                            <h2 class="mt16">
                                <span>Cheque Replacement #</span>
                                <span t-field="o.name"/>
                            </h2>
                            <div class="row mt32 mb32" id="informations">
                                <div t-if="o.contract_id" class="col-auto col-3 mw-100 mb-2">
                                    <strong>Contract No:</strong>
                                    <p class="m-0" t-field="o.contract_id.name"/>
                                </div>
                                <div t-if="o.replacement_date" class="col-auto col-3 mw-100 mb-2">
                                    <strong>Date:</strong>
                                    <p class="m-0" t-field="o.replacement_date" t-options='{"widget": "date"}'/>
                                </div>
                                <div t-if="o.unit_id" class="col-auto col-3 mw-100 mb-2">
                                    <strong>Unit No:</strong>
                                    <p class="m-0" t-field="o.unit_id.name"/>
                                </div>
                                <div t-if="o.tenant_id" class="col-auto col-3 mw-100 mb-2">
                                    <strong>Tenant:</strong>
                                    <p class="m-0" t-field="o.tenant_id.name"/>
                                </div>
<!--                                <div t-if="o.user_id.name" class="col-auto col-3 mw-100 mb-2">-->
<!--                                    <strong>Salesperson:</strong>-->
<!--                                    <p class="m-0" t-field="doc.user_id"/>-->
<!--                                </div>-->
                            </div>
                            <p>

                                <span>Pursuant to my rental payments for the above unit occupied by me, I kindly request permission to</span><br/>
                                <span>•	Replace existing cheque with a new cheque issued.</span>
                            </p>
                            <h6>REPLACING CHEQUE DETAILS</h6>
                            <table class="table table-sm o_main_table">
                                <!-- In case we want to repeat the header, remove "display: table-row-group" -->
                                <!--                                style="display: table-row-group"-->
                                <thead>
                                    <tr>
                                        <th class="text-center">
                                            <strong>Bank</strong>
                                        </th>
                                        <th class="text-center">
                                            <strong>Cheque No</strong>
                                        </th>
                                        <th class="text-center">
                                            <strong>Date</strong>
                                        </th>
                                        <th class="text-center">
                                            <strong>Amount</strong>
                                        </th>
                                        <th class="text-center">
                                            <strong>Status</strong>
                                        </th>
                                        <th class="text-center">
                                            <strong>Remarks</strong>
                                        </th>

                                    </tr>
                                    <tbody class="sale_tbody">
                                        <t t-set="row_no" t-value="1"/>
                                        <t t-foreach="o.replacement_line_ids" t-as="line">
                                            <tr>
<!--                                                <td class="text-center" name="row_no">-->
<!--                                                    <span t-esc="row_no"/>-->
<!--                                                    <t t-set="row_no" t-value="row_no+1"/>-->
<!--                                                </td>-->
                                                <td class="text-center">
                                                    <span t-field="line.bank_id.name"/>
                                                </td>
                                                <td class="text-center">
                                                    <span t-field="line.ref_no"/>
                                                </td>
                                                <td class="text-center">
                                                    <span t-field="line.ref_date" t-options='{"widget": "date"}'/>
                                                </td>
                                                <td class="text-center">
                                                    <span t-field="line.amount"/>
                                                </td>
                                                <td class="text-center">
                                                        <span t-field="line.state"/>
                                                    </td>
                                                <td class="text-center">
                                                        <span t-field="line.new_name"/>
                                                    </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </thead>
                            </table>
                            <h6>NEW PAYMENT DETAILS</h6>
                            <table class="table table-sm o_main_table">
                                <!-- In case we want to repeat the header, remove "display: table-row-group" -->
                                <!--                                style="display: table-row-group"-->
                                <thead>
                                    <tr>
                                        <th class="text-center">
                                            <strong>Mode</strong>
                                        </th>
                                        <th class="text-center">
                                            <strong>Cheque No</strong>
                                        </th>
                                        <th class="text-center">
                                            <strong>Date</strong>
                                        </th>
                                        <th class="text-center">
                                            <strong>Bank</strong>
                                        </th>
                                        <th class="text-center">
                                            <strong>Amount</strong>
                                        </th>
                                    </tr>
                                    <tbody class="sale_tbody">
                                        <t t-set="row_no" t-value="1"/>
                                        <t t-foreach="o.replacement_line_ids" t-as="line">
                                            <tr>
<!--                                                <td class="text-center" name="row_no">-->
<!--                                                    <span t-esc="row_no"/>-->
<!--                                                    <t t-set="row_no" t-value="row_no+1"/>-->
<!--                                                </td>-->
                                                <td class="text-center">
                                                    <span t-field="line.new_payment_mode"/>
                                                </td>
                                                <td class="text-center">
                                                    <span t-field="line.new_ref_no"/>
                                                </td>
                                                <td class="text-center">
                                                    <span t-field="line.new_ref_date" t-options='{"widget": "date"}'/>
                                                </td>
                                                <td class="text-center">
                                                    <span t-field="line.new_bank_id.name"/>
                                                </td>
                                                <td class="text-center">
                                                    <span t-field="line.new_amount"/>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </thead>
                            </table>
                            <p>
                                <span>I undertake to pay all applicable ADPM fees and charges in cash when applicable.</span>
                            </p>
                            <p t-if="o.note">
                                <strong>Notes:</strong>
                                <span t-field="o.note"/>
                            </p>
                        </div>
<!--                        <div class="row">-->
<!--                            <div class="col-3" style="right;">-->
<!--                                <p class="text-center" style="padding-left:5mm;">-->
<!--                                    <br/>-->
<!--                                    <span t-esc="o.env.user.name"/>-->
<!--                                    <br/>-->
<!--                                    <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y %H:%M')"/>-->
<!--                                    <br/>-->
<!--                                </p>-->
<!--                                &lt;!&ndash;                                <p class="text-center"&ndash;&gt;-->
<!--                                &lt;!&ndash;                                   style="padding-left:5mm; border-top:1px solid black; border-length: 7px;">&ndash;&gt;-->
<!--                                &lt;!&ndash;                                    Prepared by&ndash;&gt;-->
<!--                                &lt;!&ndash;                                </p>&ndash;&gt;-->
<!--                            </div>-->
<!--                        </div>-->
<!--                        <p class="text-center">-->
<!--                            <br/>-->
<!--                            This is a system Generated document and does not require any signature or company stamp.-->
<!--                        </p>-->
                    </t>
                </t>
            </t>
        </template>
    </data>
</odoo>