<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mbk_pms_unit_tree" model="ir.ui.view">
        <field name="name">mbk_pms.unit.tree</field>
        <field name="model">mbk_pms.unit</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name" string="Unit Name"/>
                <field name="type_id"/>
                <field name="status"/>
                <field name="customer_id" optional="show"/>
                <field name="state" widget="badge" decoration-success="status == 'occupied'"
                       decoration-warning="status == 'maintenance'" decoration-info="state == 'available'"
                       decoration-danger="status == 'non-renewal'" decoration-muted="state == 'booked'"/>
            </list>
        </field>
    </record>
    <record id="view_mbk_pms_unit_form" model="ir.ui.view">
        <field name="name">mbk_pms.unit.form</field>
        <field name="model">mbk_pms.unit</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar" invisible="not is_unit"
                           statusbar_visible="booked,available,occupied, unavailable"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" name="action_view_contracts"
                                icon="fa-file-contract">
                            <field string="Total Contracts" name="contract_count" widget="statinfo"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="type_id"/>
                            <field name="property_id" options="{'no_create': True}"/>
                            <field name="sq_ft"/>
                            <field name="rent"/>
                            <field name="no_of_beds"/>
                            <field name="contract_id" options="{'no_create': True}"/>
                            <field name="customer_id" options="{'no_create': True}"/>
                            <field name="state_id" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="code"/>
                            <field name="rn_id"/>
                            <field name="status"/>
                            <field name="available_from_date" invisible="not available_from_date"/>
                            <field name="use_type"/>
                            <field name="no_of_baths"/>
                            <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}"/>
                            <field name="unit_ref_id" groups="base.group_no_one"/>
                            <field name="active" invisible="1"/>
                            <field name="is_unit" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
                <!-- Chatter -->
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>
    <record id="view_mbk_pms_unit_graph" model="ir.ui.view">
        <field name="name">mbk_pms.unit.graph</field>
        <field name="model">mbk_pms.unit</field>
        <field name="arch" type="xml">
            <graph string="Unit Status" sample="1">
                <field name="state_id"/>
                <field name="status"/>
            </graph>
        </field>
    </record>
    <record id="view_mbk_pms_unit_pivot" model="ir.ui.view">
        <field name="name">mbk_pms.unit.pivot</field>
        <field name="model">mbk_pms.unit</field>
        <field name="arch" type="xml">
            <pivot string="Unit Status" sample="1">
                <field name="state_id"/>
                <field name="property_id"/>
                <field name="status"/>
            </pivot>
        </field>
    </record>
    <record id="view_mbk_pms_unit_search" model="ir.ui.view">
        <field name="name">mbk_pms.unit.search</field>
        <field name="model">mbk_pms.unit</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Unit Name"
                       filter_domain="['|', ('name', 'ilike', self), ('code', 'ilike', self)]"/>
                <field name="code"/>
                <field name="type_id"/>
                <field name="property_id" string="Property"/>
                <field name="status"/>
                <filter name="filter_type_active" string="Active"
                        domain="[('is_unit', '=', True), ('status', '!=', 'inactive')]"/>
                <filter name="filter_type_archived" string="Archived" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_by_status" context="{'group_by':'status'}"/>
                    <filter string="Type" name="group_by_type_id" context="{'group_by':'type_id'}"/>
                    <filter string="Emirate" name="group_by_state_id" context="{'group_by':'state_id'}"/>
                </group>
                <searchpanel>
                    <field name="property_id" string='Properties' enable_counters="1"/>
                </searchpanel>
            </search>
        </field>
    </record>

    <record id="action_mbk_pms_unit" model="ir.actions.act_window">
        <field name="name">Units</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">mbk_pms.unit</field>
        <field name="view_mode">list,form,graph,pivot</field>
        <field name="context">{'search_default_filter_type_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new unit
            </p>
        </field>
    </record>

    <menuitem id="menu_mbk_pms_unit"
              name="Property Units"
              action="action_mbk_pms_unit"
              parent="menu_mbk_pms_master"
              sequence="10"/>
</odoo>