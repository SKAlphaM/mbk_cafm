<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mbk_pms_payment_collection_kanban" model="ir.ui.view">
        <field name="name">mbk_pms.payment_collection.kanban</field>
        <field name="model">mbk_pms.payment_collection</field>
        <field name="arch" type="xml">
            <kanban sample="1">
                <field name="name"/>
                <field name="receipt_date"/>
                <field name="contract_id"/>
                <field name="unit_id"/>
                <field name="property_id"/>
                <field name="tenant_id"/>
                <field name="state"/>
                <field name="activity_ids"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <ul>
                                    <li>
                                        <strong>No:
                                            <field name="name"/> <field name="receipt_date"/>
                                        </strong>
                                    </li>
                                    <li>
                                        Contract No:
                                        <field name="contract_id"/>
                                    </li>
                                    <li>
                                        Unit:
                                        <field name="unit_id"/>
                                    </li>
                                    <li>
                                        Tenant:
                                        <field name="tenant_id"/>
                                    </li>
                                    <li>
                                        State:
                                        <field name="state" widget="badge" decoration-success="state == 'done'"
                                               decoration-info="state == 'active'"
                                               decoration-muted="state == 'cancel'"/>
                                        <field name="activity_ids" widget="kanban_activity"/>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_mbk_pms_payment_collection_tree" model="ir.ui.view">
        <field name="name">mbk_pms.payment_collection.tree</field>
        <field name="model">mbk_pms.payment_collection</field>
        <field name="arch" type="xml">
            <list sample="1" decoration-success="state == 'done'" decoration-muted="state == 'cancel'">
                <field name="name"/>
                <field name="receipt_date"/>
                <field name="contract_id"/>
                <field name="tenant_id"/>
                <field name="unit_id" optional="show"/>
                <field name="net_amount"/>
                <field name="property_id" optional="hide"/>
                <field name="owner_user_id" optional="hide"/>
                <field name="state" widget="badge" decoration-success="state == 'done'"
                       decoration-info="state =='active'" decoration-warning="state == 'draft'" decoration-muted="state == 'cancel'"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>
    <!-- Receipt Voucher : views -->
    <record id="view_mbk_pms_payment_collection_form" model="ir.ui.view">
        <field name="name">mbk_pms.payment_collection.form</field>
        <field name="model">mbk_pms.payment_collection</field>
        <field name="arch" type="xml">
            <form string="Receipt Voucher" duplicate="0">
                <header>
                    <button string="Confirm" name="action_confirm" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button string="Set to Draft" name="action_draft" type="object" invisible="state != 'cancel'"/>
                    <button string="Cancel" name="action_cancel" type="object" confirm="Are you sure to continue" invisible="state not in ('draft','active')"/>
                    <field name="state" widget="statusbar" invisible="not active"
                           statusbar_visible="draft,active"/>
                </header>
                <sheet>
                    <div invisible="active">
                        <span class="badge badge-warning float-right">Canceled</span>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="New" readonly="True"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="receipt_date" readonly="True" invisible="1"/>
                            <field name="tenant_id" readonly="True" options="{'no_create': True, 'no_open': True}"/>
                            <field name="unit_id" readonly="True" options="{'no_create': True, 'no_open': True}"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group>
                            <field name="contract_id"/>
                            <field name="owner_user_id" string="Requested By"
                                   options="{'no_create': True, 'no_open': True}" readonly="True"/>
                            <field name="property_id" options="{'no_create': True, 'no_open': True}"/>
                            <field name="company_id" options="{'no_create': True}" groups="base.group_multi_company"/>
                            <field name="payment_ref_id" readonly="True" groups="base.group_no_one"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Receipt Details" name="receipt_line_ids">
                            <field name="receipt_line_ids" readonly="state in ('active', 'cancel')">
                                <list editable="bottom">
                                    <field name="payment_line_id" options="{'no_create': True}" readonly="True"/>
                                    <field name="service_id" readonly="payment_line_id"/>
                                    <field name="name"/>
                                    <field name="payment_mode" readonly="payment_line_id"/>
                                    <field name="ref_date"/>
                                    <field name="ref_no"/>
                                    <field name="bank_id"/>
                                    <field name="contract_id" invisible="1"/>
                                    <field name="amount" sum="Total Amount"/>
                                </list>
                                <form>
                                    <group>
                                        <field name="payment_line_id" options="{'no_create': True}"/>
                                        <field name="payment_mode"/>
                                        <field name="ref_date"/>
                                        <field name="ref_no"/>
                                        <field name="bank_id"/>
                                        <field name="contract_id" invisible="1"/>
                                        <field name="amount" sum="Total Amount"/>
                                    </group>
                                </form>
                            </field>
                        </page>
                    </notebook>
                    <field name='note' placeholder="Internal Notes"/>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>


    <record id="view_mbk_pms_payment_collection_search" model="ir.ui.view">
        <field name="name">mbk_pms.payment_collection.search</field>
        <field name="model">mbk_pms.payment_collection</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Receipt No/Tenant"
                       filter_domain="['|', ('name', 'ilike', self), ('tenant_id', 'ilike', self)]"/>
                <field name="contract_id"/>
                <field name="unit_id"/>
                <field name="property_id"/>
                <field name="receipt_date"/>
                <field name="net_amount"/>
                <filter name="filter_type_active" string="Active"
                        domain="[('state', '=', 'Active')]"/>
                <separator/>
                <filter name="filter_type_active" string="Active" domain="[('state', '=', 'active')]"/>
                <separator/>
                <filter name="filter_type_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <separator/>
                <filter name="filter_type_cancel" string="Cancelled" domain="[('state', '=', 'cancel')]"/>
                <separator/>
                <filter name="filter_type_receipt_date" string="Date" date="receipt_date"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_by_state" context="{'group_by':'state'}"/>
                    <filter string="Tenant" name="group_by_tenant_id" context="{'group_by':'tenant_id'}"/>
                    <filter string="Contract" name="group_by_contract_id" context="{'group_by':'contract_id'}"/>
                    <filter string="Unit" name="group_by_unit_id" context="{'group_by':'unit_id'}"/>
                    <filter string="Property" name="group_by_property_id" context="{'group_by':'property_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_mbk_pms_payment_collection" model="ir.actions.act_window">
        <field name="name">Payment Collection</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">mbk_pms.payment_collection</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new payment collection
            </p>
        </field>
    </record>

    <menuitem id="menu_mbk_pms_payment_collection"
              name="Payment Collection"
              action="action_mbk_pms_payment_collection"
              parent="menu_mbk_pms_payment"
              sequence="10"/>
</odoo>