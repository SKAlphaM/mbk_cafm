<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record id="view_mbk_pms_unit_type_tree" model="ir.ui.view">
            <field name="name">mbk_pms.unit_type.tree</field>
            <field name="model">mbk_pms.unit_type</field>
            <field name="arch" type="xml">
                <list>
                    <field name="code"/>
                    <field name="name" string="Unit Type Name"/>
                </list>
            </field>
        </record>
        <record id="view_mbk_pms_unit_type_form" model="ir.ui.view">
            <field name="name">mbk_pms.unit_type.form</field>
            <field name="model">mbk_pms.unit_type</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="ref_id" groups="base.group_no_one"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                            <group>
                                <field name="code"/>
                                <field name="active" invisible="1"/>
                            </group>
                        </group>
                        <group>
                            <field name="description"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="view_mbk_pms_unit_type_search" model="ir.ui.view">
            <field name="name">mbk_pms.unit_type.search</field>
            <field name="model">mbk_pms.unit_type</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name" string="Unit Type Name" filter_domain="['|', ('name', 'ilike', self), ('code', 'ilike', self)]"/>
                    <field name="code"/>
                    <filter name="filter_type_archived" string="Archived" domain="[('active', '=', False)]"/>
                </search>
            </field>
        </record>

    <record id="action_mbk_pms_unit_type" model="ir.actions.act_window">
        <field name="name">Unit Types</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">mbk_pms.unit_type</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Unit Type
            </p>
        </field>
    </record>

    <menuitem id="menu_mbk_pms_unit_type"
              name="Unit Types"
              action="action_mbk_pms_unit_type"
              parent="menu_mbk_pms_master"
              sequence="30"/>
</odoo>