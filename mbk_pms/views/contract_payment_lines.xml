<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mbk_pms_contract_payment_line_tree" model="ir.ui.view">
        <field name="name">mbk_pms.contract_payment_line.tree</field>
        <field name="model">mbk_pms.contract.payment.line</field>
        <field name="arch" type="xml">
            <list delete="0">
                <field name="contract_id" options="{'no_create': True}"/>
                <field name="tenant_id" options="{'no_create': True}"/>
                <field name="service_id" options="{'no_create': True}"/>
                <field name="name"/>
                <field name="ref_date"/>
                <field name="payment_mode"/>
                <field name="amount" sum="Total Amount"/>
                <field name="ref_no"/>
                <field name="bank_id"/>
                <field name="chq_type"/>
                <field name="from_date" optional="hide" force_save="1" widget="date"/>
                <field name="to_date" optional="hide" force_save="1" widget="date"/>
                <field name="days" sum="Total Days" optional="hide" force_save="1"/>
                <field name="depositing_bank_id" optional="hide"/>
                <field name="unit_id"/>
                <field name="property_id" optional="hide"/>
                <field name="last_activity_date" optional="hide"/>
                <field name="received_date" optional="hide"/>
                <field name="deposited_date" optional="hide"/>                
                <field name="company_id" invisible="True"/>
                <field name="state" widget="badge" decoration-success="state == 'cleared'"
                       decoration-muted="state == 'cancel'" decoration-danger="state == 'bounced'" decoration-warning="state == 'hold'"/>
            </list>
        </field>
    </record>
    <record id="view_mbk_pms_contract_payment_line_form" model="ir.ui.view">
        <field name="name">mbk_pms.unit.form</field>
        <field name="model">mbk_pms.contract.payment.line</field>
        <field name="arch" type="xml">
            <form duplicate="0" delete="0">
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,active,received,deposited,cleared"/>
                </header>
                <sheet>
                    <group>
                        <field name="contract_id" options="{'no_create': True}"/>
                        <field name="service_id" options="{'no_create': True}"/>
                        <field name="name"/>
                        <field name="ref_date"/>
                        <field name="payment_mode"/>
                        <field name="amount"/>
                        <field name="ref_no"/>
                        <field name="bank_id"/>
                        <field name="chq_type"/>
                        <field name="from_date"/>
                        <field name="to_date"/>
                        <field name="days"/>
                        <field name="depositing_bank_id"/>
                        <field name="last_activity_date"/>
                        <field name="received_date"/>
                        <field name="deposited_date"/>
                        <field name="state_id"/>
                        <field name="unit_id"/>
                        <field name="property_id"/>
                        <field name="category"/>
                        <field name="company_id" invisible="True"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
    <record id="view_mbk_pms_contract_payment_line_search" model="ir.ui.view">
        <field name="name">mbk_pms.contract_payment_line.search</field>
        <field name="model">mbk_pms.contract.payment.line</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Ref No"
                       filter_domain="['|', ('name', 'ilike', self), ('ref_no', 'ilike', self)]"/>
                <field name="ref_date"/>
                <field name="contract_id"/>
                <field name="tenant_id"/>
                <field name="unit_id"/>
                <field name="property_id"/>
                <field name="payment_mode"/>
                <field name="amount"/>
                <field name="state"/>
                <filter name="filter_type_active" string="Active" domain="[('state', 'not in', ('draft', 'cleared','bounced', 'replaced', 'cancel'))]"/>
                <separator/>
                <filter name="filter_type_cheque" string="Payment Mode: Cheque" domain="[('payment_mode', '=', 'chq')]"/>
                <separator/>
                <filter name="filter_type_ref_date" string="Cheque Date" date="ref_date"/>
                <group expand="0" string="Group By">
                    <filter string="Contract" name="group_by_contract_id" context="{'group_by':'contract_id'}"/>
                    <filter string="Tenant" name="group_by_tenant_id" context="{'group_by':'tenant_id'}"/>
                    <filter string="Unit" name="group_by_unit_id" context="{'group_by':'unit_id'}"/>
                    <filter string="Property" name="group_by_property_id" context="{'group_by':'property_id'}"/>
                    <filter string="State" name="group_by_state" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_mbk_pms_contract_payment_line" model="ir.actions.act_window">
        <field name="name">Contract Payment Details</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">mbk_pms.contract.payment.line</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a payment details
            </p>
        </field>
    </record>

    <menuitem id="menu_mbk_pms_contract_payment_line"
              name="Contract Payment Details"
              action="action_mbk_pms_contract_payment_line"
              parent="menu_mbk_pms_payment"
              sequence="90"/>
</odoo>