<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mbk_pms_break_request_tree" model="ir.ui.view">
        <field name="name">mbk_pms.break_request.tree</field>
        <field name="model">mbk_pms.break_request</field>
        <field name="arch" type="xml">
            <list sample="1" decoration-muted="state == 'cancel'">
                <field name="name"/>
                <field name="request_date"/>
                <field name="tenant_id"/>
                <field name="contract_id"/>
                <field name="units"/>
                <field name="contract_amount"/>
                <field name="start_date" optional="hide"/>
                <field name="expiry_date" optional="hide"/>
                <field name="no_of_days" optional="hide"/>
                <field name="remaining_days"/>
                <field name="owner_user_id" optional="hide"/>
                <field name="state" widget="badge" decoration-info="state =='active'" decoration-warning="state == 'draft'" decoration-muted="state == 'cancel'"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>
    <!-- Break Request Voucher : views -->
    <record id="view_mbk_pms_break_request_form" model="ir.ui.view">
        <field name="name">mbk_pms.break_request.form</field>
        <field name="model">mbk_pms.break_request</field>
        <field name="arch" type="xml">
            <form string="Breaking Request" duplicate="0">
                <header>
                    <button string="Confirm" name="action_confirm" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button string="Set to Draft" name="action_draft" type="object" invisible="state not in ('cancel', 'active')"/>
                    <button string="Cancel" name="action_cancel" type="object" confirm="Are you sure to continue" invisible="state not in ('draft','active')"/>
                    <field name="state" widget="statusbar" invisible="not active"
                           statusbar_visible="draft,active"/>
                </header>
                <sheet>
                    <div invisible="active">
                        <span class="badge badge-warning float-right">Canceled</span>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="New" readonly="True"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="request_date" readonly="True"/>
                            <field name="tenant_id" options="{'no_create': True, 'no_open': True}"/>

                            <field name="units"/>
                            <field name="start_date"/>
                            <field name="breaking_date"/>
                            <field name="remaining_days" force_save="1"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group>
                            <field name="contract_id" options="{'no_create': True}"/>
                            <field name="contract_amount"/>
                            <field name="property_id"/>
                            <field name="expiry_date"/>
                            <field name="no_of_days" force_save="1"/>
                            <field name="owner_user_id" string="Created By"
                                   options="{'no_create': True, 'no_open': True}" readonly="True" invisible="1"/>
                            <field name="break_contract_id" options="{'no_create': True}" invisible="not break_contract_id" force_save="1"/>
                            <field name="company_id" options="{'no_create': True}" groups="base.group_multi_company"/>
                            <field name="currency_id" options="{'no_create': True, 'no_open': True}" invisible="1"/>
                        </group>
                    </group>
                    <field name='note' placeholder="Internal Notes"/>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>


    <record id="view_mbk_pms_break_request_search" model="ir.ui.view">
        <field name="name">mbk_pms.break_request.search</field>
        <field name="model">mbk_pms.break_request</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Break Request No"
                       filter_domain="['|', ('name', 'ilike', self), ('tenant_id', 'ilike', self)]"/>
                <field name="contract_id"/>
                <field name="units"/>
                <filter name="filter_type_active" string="Active"
                        domain="[('state', '=', 'Active')]"/>
                <separator/>
                <filter name="filter_type_active" string="Active" domain="[('state', '=', 'active')]"/>
                <separator/>
                <filter name="filter_type_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <separator/>
                <filter name="filter_type_cancel" string="Cancelled" domain="[('state', '=', 'cancel')]"/>
                <separator/>
                <filter name="filter_type_request_date" string="Date" date="request_date"/>
                <group expand="0" string="Group By">
                    <filter string="Tenant" name="group_by_tenant_id" context="{'group_by':'tenant_id'}"/>
                    <filter string="Contract" name="group_by_contract_id" context="{'group_by':'contract_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_mbk_pms_break_request" model="ir.actions.act_window">
        <field name="name">Break Lease Contract Request</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">mbk_pms.break_request</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Breaking Lease Contract Request
            </p>
        </field>
    </record>

    <menuitem id="menu_mbk_pms_break_request"
              name="Break Request"
              action="action_mbk_pms_break_request"
              parent="menu_mbk_pms_break_lease_menu"
              sequence="10"/>
</odoo>