<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record id="view_mbk_pms_services_tree" model="ir.ui.view">
            <field name="name">mbk_pms.service.tree</field>
            <field name="model">mbk_pms.service</field>
            <field name="arch" type="xml">
                <list>
                    <field name="sequence" widget="handle"/>
                    <field name="code"/>
                    <field name="name"/>
                    <field name="category"/>
                </list>
            </field>
        </record>
        <record id="view_mbk_pms_services_form" model="ir.ui.view">
            <field name="name">mbk_pms.service.form</field>
            <field name="model">mbk_pms.service</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="is_one_time" widget="boolean_toggle"/>
                                <field name="is_separate_chq" widget="boolean_toggle"/>
                                <field name="is_tax" widget="boolean_toggle"/>
                                <field name="on_renewal" widget="boolean_toggle"/>
                                <field name="bank_account_id"/>
                                <field name="account_id"/>
                                <field name="advance_account_id"/>
                                <field name="ref_id" groups="base.group_no_one"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                            <group>
                                <field name="code"/>
                                <field name="price"/>
                                <field name="category"/>
                                <field name="arabic_name"/>
                                <field name="active" invisible="1"/>
                            </group>
                            <field name="description"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="view_mbk_pms_services_search" model="ir.ui.view">
            <field name="name">mbk_pms.service.search</field>
            <field name="model">mbk_pms.service</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name" filter_domain="['|', ('name', 'ilike', self), ('code', 'ilike', self)]"/>
                    <field name="code"/>
                    <filter name="filter_type_archived" string="Archived" domain="[('active', '=', False)]"/>
                </search>
            </field>
        </record>

    <record id="action_mbk_pms_services" model="ir.actions.act_window">
        <field name="name">Lease Services</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">mbk_pms.service</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new services
            </p>
        </field>
    </record>

    <menuitem id="menu_mbk_pms_services"
              name="Services"
              action="action_mbk_pms_services"
              parent="menu_mbk_pms_config"
              sequence="30"/>
</odoo>