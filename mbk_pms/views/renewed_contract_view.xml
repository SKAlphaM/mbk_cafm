<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_mbk_pms_renewed_contract" model="ir.actions.act_window">
        <field name="name">Lease Contract Renewal</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">mbk_pms.contract</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('parent_contract_id', '!=', False), ('name', '!=', 'Draft')]</field>
        <field name="context">{'search_default_filter_type_todo': 1}</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new renewal contract
            </p>
        </field>
    </record>
    <menuitem id="menu_mbk_pms_view_renewed_contract"
              name="Renewed Contracts"
              action="action_mbk_pms_renewed_contract"
              parent="menu_mbk_pms_renewal_offer"
              sequence="30"/>
</odoo>