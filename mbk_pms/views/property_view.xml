<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mbk_pms_property_kanban" model="ir.ui.view">
        <field name="name">mbk_pms.property.kanban</field>
        <field name="model">mbk_pms.property</field>
        <field name="arch" type="xml">
            <kanban sample="1">
                <field name="id"/>
                <field name="name"/>
                <field name="code"/>
                <field name="property_type_id"/>
                <field name="status"/>
                <field name="state_id"/>
                <field name="occupancy_percentage"/>
                <field name="unit_count"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record_has_image_fill">
                            <t t-set="background_image"
                               t-value="kanban_image('mbk_pms.property', 'image', record.id.raw_value)"/>
                            <div class="o_kanban_image d-none d-md-block"
                                 t-attf-style="background-image:url('#{background_image}')">
                                <!--                                    <img class="o_kanban_image_inner_pic" t-att-src="kanban_image('mbk_pms.property', 'image', record.id.raw_value)"/>-->
                            </div>
                            <div class="oe_kanban_details d-flex flex-column">
                                <strong class="o_kanban_record_title oe_partner_heading">
                                    <field name="name"/>
                                </strong>
                                <ul>
                                    <li>
                                        <field name="property_type_id"/> (T: <field name="unit_count"/>, O: <field name="unit_occupied"/>, N: <field name="unit_non_renewal"/>, V: <field name="unit_vacant"/>)
                                    </li>
                                    <li>
                                        <field name="state_id"/>
                                    </li>
                                    <li>
                                        <field name="occupancy_percentage" widget="progressbar" decoration-success="occupancy_percentage &gt; 80" decoration-danger="occupancy_percentage &lt; 40"/>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <record id="view_mbk_pms_property_tree" model="ir.ui.view">
        <field name="name">mbk_pms.property.tree</field>
        <field name="model">mbk_pms.property</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name" string="Property Name"/>
                <field name="property_type_id"/>
                <field name="status" optional="hide"/>
                <field name="unit_count" string="Units"/>
                <field name="unit_occupied" string="Occupied" optional="hide"/>
                <field name="unit_vacant" string="Vacant"/>
                <field name="unit_non_renewal" string="Non Renewal" optional="hide"/>
                <field name="occupancy_percentage" widget="progressbar" decoration-success="occupancy_percentage &gt; 80" decoration-danger="occupancy_percentage &lt; 40"/>
            </list>
        </field>
    </record>
    <record id="view_mbk_pms_property_form" model="ir.ui.view">
        <field name="name">mbk_pms.property.form</field>
        <field name="model">mbk_pms.property</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" name="action_view_units"  icon="fa-building">
                            <field string="Total" name="unit_count" widget="statinfo"/>
                        </button>
                        <button class="oe_stat_button" type="object" name="action_view_units_occupied"  icon="fa-battery-full">
                            <field string="Occupied" name="unit_occupied" widget="statinfo"/>
                        </button>
                        <button class="oe_stat_button" type="object" name="action_view_units_non_renewal"  icon="fa-exclamation">
                            <field string="Non Renewal" name="unit_non_renewal" widget="statinfo"/>
                        </button>
                        <button class="oe_stat_button" type="object" name="action_view_units_vacant"  icon="fa-battery-empty">
                            <field string="Vacant" name="unit_vacant" widget="statinfo"/>
                        </button>
                    </div>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="property_type_id" options="{'no_create': True}"/>
                            <field name="country_id" options="{'no_create': True}"/>
                            <field name="city"/>
                            <field name="address"/>
                        </group>
                        <group>
                            <field name="code"/>
                            <field name="status"/>
                            <field name="state_id" options="{'no_create': True}"/>
                            <field name="street"/>
                            <field name="contact_no" widget="phone"/>
                            <field name="active" invisible="1"/>
                            <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}"/>
                            <field name="property_ref_id" groups="base.group_no_one"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
                <!-- Chatter -->
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>
    <record id="view_mbk_pms_property_search" model="ir.ui.view">
        <field name="name">mbk_pms.property.search</field>
        <field name="model">mbk_pms.property</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Property Name"
                       filter_domain="['|', ('name', 'ilike', self), ('code', 'ilike', self)]"/>
                <field name="code"/>
                <field name="property_type_id"/>
                <field name="status"/>
                <filter name="filter_type_status" string="Active" domain="[('status', '=', 'active')]"/>
                <separator/>
                <filter name="filter_type_state_auh" string="Abu Dhabi" domain="[('state_id', '=', 546)]"/>
                <filter name="filter_type_state_dxb" string="Dubai" domain="[('state_id', '=', 548)]"/>
                <filter name="filter_type_state_fuh" string="Fujairah" domain="[('state_id', '=', 549)]"/>
                <separator/>
                <filter name="filter_type_archived" string="Archived" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Property Type" name="group_by_property_type_id" context="{'group_by':'property_type_id'}"/>
                    <filter string="Emirate" name="group_by_state_id" context="{'group_by':'state_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_mbk_pms_property" model="ir.actions.act_window">
        <field name="name">Properties</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">mbk_pms.property</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new property
            </p>
        </field>
    </record>

    <menuitem id="menu_mbk_pms_property"
              name="Properties"
              action="action_mbk_pms_property"
              parent="menu_mbk_pms_master"
              sequence="0"/>
</odoo>