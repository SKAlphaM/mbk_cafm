<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mbk_pms_break_contract_tree" model="ir.ui.view">
        <field name="name">mbk_pms.break_contract.tree</field>
        <field name="model">mbk_pms.break_contract</field>
        <field name="arch" type="xml">
            <list sample="1" decoration-muted="state == 'cancel'">
                <field name="name"/>
                <field name="break_date"/>
                <field name="tenant_id"/>
                <field name="contract_id"/>
                <field name="units"/>
                <field name="contract_amount"/>
                <field name="start_date" optional="hide"/>
                <field name="expiry_date" optional="hide"/>
                <field name="no_of_days" optional="hide"/>
                <field name="remaining_days"/>
                <field name="owner_user_id" optional="hide"/>
                <field name="state" widget="badge" decoration-info="state =='active'" decoration-warning="state == 'draft'" decoration-muted="state == 'cancel'"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>
    <!-- Break Contract Voucher : views -->
    <record id="view_mbk_pms_break_contract_form" model="ir.ui.view">
        <field name="name">mbk_pms.break_contract.form</field>
        <field name="model">mbk_pms.break_contract</field>
        <field name="arch" type="xml">
            <form string="Breaking Request" duplicate="0">
                <header>
                    <button string="Submit for Approval" name="action_done_update_state_wizard" type="object" class="oe_highlight"  invisible = "state != 'draft'"/>
                    <button string="Confirm" name="action_confirm_update_state_wizard" type="object" class="oe_highlight"
                            invisible = "state != 'confirm'"/>
                    <button string="Reject" name="action_reject_update_state_wizard" type="object"
                            invisible = "state != 'confirm'"/>
                    <button string="Set to Draft" name="action_draft" type="object" invisible="state not in ('active','refuse')"/>
                    <button string="Cancel" name="action_cancel" type="object" confirm="Are you sure to continue" invisible="state not in ('draft','active')"/>
                    <field name="state" widget="statusbar" invisible="not active"
                           statusbar_visible="draft,active,done"/>
                </header>
                <sheet>
                    <div invisible="active">
                        <span class="badge badge-warning float-right">Canceled</span>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="New" readonly="True"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="break_date" readonly="True"/>
                            <field name="tenant_id" options="{'no_create': True, 'no_open': True}"/>
                            <field name="units"/>
                            <field name="property_id"/>
                            <field name="start_date"/>
                            <field name="breaking_date"/>
                            <field name="remaining_days" force_save="1"/>
                            <field name="penalty_days"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group>
                            <field name="breaking_request_id" options="{'no_open': True}"/>
                            <field name="contract_id" options="{'no_create': True}"/>
                            <field name="contract_amount" />
                            <field name="security_deposit"/>
                            <field name="expiry_date"/>
                            <field name="no_of_days" force_save="1"/>
                            <field name="total_days" force_save="1" invisible="True"/>
                            <field name="owner_user_id" string="Created By"
                                   options="{'no_create': True, 'no_open': True}" readonly="True" invisible="1"/>
                            <field name="company_id" options="{'no_create': True}" groups="base.group_multi_company"/>
                            <field name="currency_id" options="{'no_create': True, 'no_open': True}" invisible="1"/>
                        </group>
                    </group>
                    <separator string="Tenant Rent and  SD Received Summary"/>
                    <group>
                        <field name="rent_received" force_save="1"/>
                        <field name="balance_security_deposit" force_save="1"/>
                        <field name="total_received" string="Total Received" force_save="1"/>
                    </group>
                    <button icon="fa-minus" string=" Load Deduction Details" name="action_load_deductions" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <field name="deduction_line_ids" readonly="state in ('active','cancel')">
                        <list editable="bottom">
                            <field name="deduction_id" options="{'no_create': True, 'no_open': True}"/>
                            <field name="name"/>
                            <field name="amount"/>
                            <field name="company_id"  invisible="True"/>
                        </list>
                        <form>
                            <group>
                                <field name="deduction_id" options="{'no_create': True, 'no_open': True}"/>
                                <field name="name"/>
                                <field name="amount" sum="Total Deductions"/>
                                <field name="company_id"  invisible="True"/>
                            </group>
                        </form>
                    </field>
                    <group class="oe_subtotal_footer">
                        <field name="total_received" string="Total Received" force_save="1"/>
                        <field name="total_deductions" string="Total Due From Tenant" force_save="1"/>
                        <field name="net_due_amount" string="Net Amount Due To Tenant" class="oe_subtotal_footer_separator" force_save="1"/>
                     </group>
                    <field name='note' placeholder="Internal Notes"/>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>


    <record id="view_mbk_pms_break_contract_search" model="ir.ui.view">
        <field name="name">mbk_pms.break_contract.search</field>
        <field name="model">mbk_pms.break_contract</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Break Contract"
                       filter_domain="['|', ('name', 'ilike', self), ('tenant_id', 'ilike', self)]"/>
                <field name="tenant_id"/>
                <field name="contract_id"/>
                <field name="units"/>
                <filter name="filter_type_active" string="Active"
                        domain="[('state', '=', 'Active')]"/>
                <separator/>
                <filter name="filter_type_active" string="Active" domain="[('state', '=', 'active')]"/>
                <separator/>
                <filter name="filter_type_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <separator/>
                <filter name="filter_type_cancel" string="Cancelled" domain="[('state', '=', 'cancel')]"/>
                <separator/>
                <filter name="filter_type_break_date" string="Date" date="break_date"/>
                <group expand="0" string="Group By">
                    <filter string="Tenant" name="group_by_tenant_id" context="{'group_by':'tenant_id'}"/>
                    <filter string="Contract" name="group_by_contract_id" context="{'group_by':'contract_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_mbk_pms_break_contract" model="ir.actions.act_window">
        <field name="name">Break Lease Contract</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">mbk_pms.break_contract</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Break Lease Contract
            </p>
        </field>
    </record>

    <menuitem id="menu_mbk_pms_break_contract"
              name="Break Contract"
              action="action_mbk_pms_break_contract"
              parent="menu_mbk_pms_break_lease_menu"
              sequence="20"/>
</odoo>