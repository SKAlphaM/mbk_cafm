<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_pms_user_own" model="res.groups">
        <field name="name">User: Own Documents Only</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="category_id" ref="base.module_category_property_management"/>
    </record>
    <record id="group_pms_user" model="res.groups">
        <field name="name">User</field>
        <field name="implied_ids" eval="[(4, ref('group_pms_user_own'))]"/>
        <field name="category_id" ref="base.module_category_property_management"/>
    </record>

    <!-- This group is only allowed to deal with Unit registration and maintenance -->
    <record id="group_pms_advisor" model="res.groups">
        <field name="name">Advisor</field>
        <field name="implied_ids" eval="[(4, ref('group_pms_user'))]"/>
        <field name="category_id" ref="base.module_category_property_management"/>
    </record>

    <record id="group_pms_manager" model="res.groups">
        <field name="name">Property Manager</field>
        <field name="implied_ids" eval="[(4, ref('group_pms_advisor'))]"/>
        <field name="category_id" ref="base.module_category_property_management"/>
        <field name="comment">The user will be able to approve documents.</field>
    </record>

    <!-- This group is only allowed to delete records -->
    <record id="group_pms_admin" model="res.groups">
        <field name="name">Property Administrator</field>
        <field name="implied_ids" eval="[(4, ref('group_pms_manager'))]"/>
        <field name="category_id" ref="base.module_category_property_management"/>
        <field name="comment">The user will have full permissions.</field>
    </record>


    <data noupdate="1">
        <!-- Rules -->

        <record id="mbk_pms_lease_offer_comp_rule" model="ir.rule">
            <field name="name">Lease Offer Company Rules</field>
            <field name="model_id" ref="model_mbk_pms_lease_offer"/>
            <field name="domain_force">['|',('company_id','=',False),('company_id', 'in', company_ids)]</field>
        </record>

        <record id="mbk_pms_lease_offer_unit_line_comp_rule" model="ir.rule">
            <field name="name">Lease Offer Unit Lines Company Rules</field>
            <field name="model_id" ref="model_mbk_pms_lease_offer_unit_line"/>
            <field name="domain_force">['|',('company_id','=',False),('company_id', 'in', company_ids)]</field>
        </record>

        <record id="mbk_pms_lease_offer_service_line_comp_rule" model="ir.rule">
            <field name="name">Lease Offer Service Lines Company Rules</field>
            <field name="model_id" ref="model_mbk_pms_lease_offer_service_line"/>
            <field name="domain_force">['|',('company_id','=',False),('company_id', 'in', company_ids)]</field>
        </record>

        <record id="mbk_pms_lease_offer_deposit_line_comp_rule" model="ir.rule">
            <field name="name">Lease Offer Deposit Lines Company Rules</field>
            <field name="model_id" ref="model_mbk_pms_lease_offer_deposit_line"/>
            <field name="domain_force">['|',('company_id','=',False),('company_id', 'in', company_ids)]</field>
        </record>

        <record id="mbk_pms_lease_offer_payment_line_comp_rule" model="ir.rule">
            <field name="name">Lease Offer Payment Lines Company Rules</field>
            <field name="model_id" ref="model_mbk_pms_lease_offer_payment_line"/>
            <field name="domain_force">['|',('company_id','=',False),('company_id', 'in', company_ids)]</field>
        </record>

        <record id="base.user_admin" model="res.users">
            <field name="groups_id" eval="[(4, ref('group_pms_admin'))]"/>
        </record>
    </data>
</odoo>
